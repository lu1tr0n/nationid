    "id",
    "validation",
    "tax-id",
    "national-id",
    "identity",
    "cedula",
    "dui",
    "nit",
    "rfc",
    "curp",
    "cpf",
    "cnpj",
    "rut",
    "cuit",
    "dni",
    "ruc",
    "ssn",
    "ein",
    "nif",
    "latam",
    "i18n",
    "validator"
  ],
  "homepage": "https://lu1tr0n.github.io/nationid_example/",
  "bugs": {
    "url": "https://github.com/lu1tr0n/nationid/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/lu1tr0n/nationid.git"
  },
  "license": "MIT",
  "author": "Luis Navarro <luis.navarro.alvarez.1991@gmail.com> (https://github.com/lu1tr0n)",
  "type": "module",
  "sideEffects": false,
