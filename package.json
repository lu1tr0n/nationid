{
  "name": "nationid",
  "version": "0.3.0",
  "description": "TypeScript-first, zero-dependency validator for national identity and tax documents from every country.",
  "keywords": [
    "id",
    "validation",
    "tax-id",
    "national-id",
    "identity",
    "cedula",
    "dui",
    "nit",
    "rfc",
    "curp",
    "cpf",
    "cnpj",
    "rut",
    "cuit",
    "dni",
    "ruc",
    "ssn",
    "ein",
    "nif",
    "latam",
    "i18n",
    "validator"
  ],
  "homepage": "https://github.com/lu1tr0n/nationid",
  "bugs": {
    "url": "https://github.com/lu1tr0n/nationid/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/lu1tr0n/nationid.git"
  },
  "license": "MIT",
  "author": "Luis Navarro <luis.navarro.alvarez.1991@gmail.com> (https://github.com/lu1tr0n)",
  "type": "module",
  "sideEffects": false,
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./algorithms": {
      "types": "./dist/algorithms/index.d.ts",
      "import": "./dist/algorithms/index.js",
      "require": "./dist/algorithms/index.cjs"
    },
    "./sv": {
      "types": "./dist/countries/sv/index.d.ts",
      "import": "./dist/countries/sv/index.js",
      "require": "./dist/countries/sv/index.cjs"
    },
    "./mx": {
      "types": "./dist/countries/mx/index.d.ts",
      "import": "./dist/countries/mx/index.js",
      "require": "./dist/countries/mx/index.cjs"
    },
    "./co": {
      "types": "./dist/countries/co/index.d.ts",
      "import": "./dist/countries/co/index.js",
      "require": "./dist/countries/co/index.cjs"
    },
    "./br": {
      "types": "./dist/countries/br/index.d.ts",
      "import": "./dist/countries/br/index.js",
      "require": "./dist/countries/br/index.cjs"
    },
    "./pe": {
      "types": "./dist/countries/pe/index.d.ts",
      "import": "./dist/countries/pe/index.js",
      "require": "./dist/countries/pe/index.cjs"
    },
    "./ar": {
      "types": "./dist/countries/ar/index.d.ts",
      "import": "./dist/countries/ar/index.js",
      "require": "./dist/countries/ar/index.cjs"
    },
    "./cl": {
      "types": "./dist/countries/cl/index.d.ts",
      "import": "./dist/countries/cl/index.js",
      "require": "./dist/countries/cl/index.cjs"
    },
    "./do": {
      "types": "./dist/countries/do/index.d.ts",
      "import": "./dist/countries/do/index.js",
      "require": "./dist/countries/do/index.cjs"
    },
    "./gt": {
      "types": "./dist/countries/gt/index.d.ts",
      "import": "./dist/countries/gt/index.js",
      "require": "./dist/countries/gt/index.cjs"
    },
    "./hn": {
      "types": "./dist/countries/hn/index.d.ts",
      "import": "./dist/countries/hn/index.js",
      "require": "./dist/countries/hn/index.cjs"
    },
    "./cr": {
      "types": "./dist/countries/cr/index.d.ts",
      "import": "./dist/countries/cr/index.js",
      "require": "./dist/countries/cr/index.cjs"
    },
    "./es": {
      "types": "./dist/countries/es/index.d.ts",
      "import": "./dist/countries/es/index.js",
      "require": "./dist/countries/es/index.cjs"
    },
    "./us": {
      "types": "./dist/countries/us/index.d.ts",
      "import": "./dist/countries/us/index.js",
      "require": "./dist/countries/us/index.cjs"
    },
    "./extract": {
      "types": "./dist/extract/index.d.ts",
      "import": "./dist/extract/index.js",
      "require": "./dist/extract/index.cjs"
    },
    "./pii": {
      "types": "./dist/pii/index.d.ts",
      "import": "./dist/pii/index.js",
      "require": "./dist/pii/index.cjs"
    },
    "./i18n": {
      "types": "./dist/i18n/index.d.ts",
      "import": "./dist/i18n/index.js",
      "require": "./dist/i18n/index.cjs"
    },
    "./i18n/es": {
      "types": "./dist/i18n/locales/es.d.ts",
      "import": "./dist/i18n/locales/es.js",
      "require": "./dist/i18n/locales/es.cjs"
    },
    "./i18n/en": {
      "types": "./dist/i18n/locales/en.d.ts",
      "import": "./dist/i18n/locales/en.js",
      "require": "./dist/i18n/locales/en.cjs"
    },
    "./i18n/pt": {
      "types": "./dist/i18n/locales/pt.d.ts",
      "import": "./dist/i18n/locales/pt.js",
      "require": "./dist/i18n/locales/pt.cjs"
    },
    "./catalog": {
      "types": "./dist/catalog/index.d.ts",
      "import": "./dist/catalog/index.js",
      "require": "./dist/catalog/index.cjs"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "dist",
    "README.md",
    "MIGRATION.md",
    "BENCHMARKS.md",
    "LICENSE",
    "CHANGELOG.md"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:dist": "vitest run --config vitest.dist.config.ts",
    "test:coverage": "vitest run --coverage",
    "typecheck": "tsc --noEmit",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "format": "biome format --write .",
    "size": "size-limit",
    "docs": "typedoc",
    "docs:check": "typedoc --emit none",
    "verify": "pnpm lint && pnpm typecheck && pnpm test && pnpm build && pnpm test:dist",
    "bench": "tsx benchmarks/validate.bench.ts && tsx benchmarks/format.bench.ts && tsx benchmarks/parse.bench.ts",
    "bench:validate": "tsx benchmarks/validate.bench.ts",
    "bench:format": "tsx benchmarks/format.bench.ts",
    "bench:parse": "tsx benchmarks/parse.bench.ts",
    "changeset": "changeset",
    "version": "changeset version",
    "release": "pnpm build && changeset publish",
    "prepublishOnly": "pnpm verify"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.0.0",
    "@brazilian-utils/brazilian-utils": "^2.3.0",
    "@changesets/cli": "^2.27.10",
    "@size-limit/preset-small-lib": "^12.1.0",
    "@types/node": "^25.6.2",
    "@types/validator": "^13.15.10",
    "@vitest/coverage-v8": "^4.1.5",
    "cpf-cnpj-validator": "^2.1.0",
    "fast-check": "^4.0.0",
    "rut.js": "^2.1.0",
    "size-limit": "^12.1.0",
    "tinybench": "^6.0.1",
    "tsup": "^8.3.0",
    "tsx": "^4.21.0",
    "typedoc": "^0.28.0",
    "typescript": "^6.0.3",
    "validator": "^13.15.35",
    "vitest": "^4.1.5"
  },
  "engines": {
    "node": ">=20"
  },
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "size-limit": [
    {
      "name": "full registry (root, all 13 countries v0.1)",
      "path": "dist/index.js",
      "limit": "20 KB"
    },
    {
      "name": "single country — sv (smallest, format+1 mod-10 + 1 mod-11)",
      "path": "dist/countries/sv/index.js",
      "limit": "3 KB"
    },
    {
      "name": "single country — br (mid, two mod-11 specs)",
      "path": "dist/countries/br/index.js",
      "limit": "3 KB"
    },
    {
      "name": "single country — mx (largest, CURP table + RFC homoclave)",
      "path": "dist/countries/mx/index.js",
      "limit": "5 KB"
    },
    {
      "name": "single country — es (DNI letter table + CIF)",
      "path": "dist/countries/es/index.js",
      "limit": "3 KB"
    },
    {
      "name": "algorithms primitives subpath",
      "path": "dist/algorithms/index.js",
      "limit": "1 KB"
    },
    {
      "name": "v0.3 — extract helpers subpath (includes full registry for getSpec)",
      "path": "dist/extract/index.js",
      "limit": "10 KB"
    },
    {
      "name": "v0.3 — pii helpers subpath (includes full registry for getSpec)",
      "path": "dist/pii/index.js",
      "limit": "10 KB"
    },
    {
      "name": "v0.3 — i18n core subpath",
      "path": "dist/i18n/index.js",
      "limit": "2 KB"
    },
    {
      "name": "v0.3 — i18n single locale (es)",
      "path": "dist/i18n/locales/es.js",
      "limit": "1 KB"
    },
    {
      "name": "v0.3 — catalog subpath (all 3 locales)",
      "path": "dist/catalog/index.js",
      "limit": "20 KB"
    }
  ]
}
