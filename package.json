  "files": [
    "dist",
    "README.md",
    "MIGRATION.md",
    "BENCHMARKS.md",
    "LICENSE",
    "CHANGELOG.md"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:dist": "vitest run --config vitest.dist.config.ts",
    "test:coverage": "vitest run --coverage",
    "typecheck": "tsc --noEmit",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "format": "biome format --write .",
    "size": "size-limit",
    "docs": "typedoc",
    "docs:check": "typedoc --emit none",
    "check:exports": "attw --pack . --profile node16",
    "check:publint": "publint --level error",
    "verify": "pnpm lint && pnpm typecheck && pnpm test && pnpm build && pnpm test:dist && pnpm check:publint",
    "bench": "tsx benchmarks/validate.bench.ts && tsx benchmarks/format.bench.ts && tsx benchmarks/parse.bench.ts",
    "bench:validate": "tsx benchmarks/validate.bench.ts",
    "bench:format": "tsx benchmarks/format.bench.ts",
    "bench:parse": "tsx benchmarks/parse.bench.ts",
    "changeset": "changeset",
    "version": "changeset version",
    "release": "pnpm build && changeset publish",
    "prepublishOnly": "pnpm verify",
    "prepare": "simple-git-hooks"
  },
  "simple-git-hooks": {
    "pre-commit": "pnpm nano-staged"
  },
  "nano-staged": {
    "*.{ts,js,jsx,tsx,json,md,yml,yaml}": "biome check --no-errors-on-unmatched --write --staged"
  },
  "devDependencies": {
    "@arethetypeswrong/cli": "^0.18.2",
    "@biomejs/biome": "^2.0.0",
    "@brazilian-utils/brazilian-utils": "^2.3.0",
    "@changesets/cli": "^2.27.10",
    "@size-limit/preset-small-lib": "^12.1.0",
    "@types/node": "^25.6.2",
    "@types/validator": "^13.15.10",
    "@vitest/coverage-v8": "^4.1.5",
    "cpf-cnpj-validator": "^2.1.0",
    "fast-check": "^4.0.0",
    "nano-staged": "^1.0.2",
    "publint": "^0.3.21",
    "rut.js": "^2.1.0",
    "simple-git-hooks": "^2.13.1",
    "size-limit": "^12.1.0",
    "tinybench": "^6.0.1",
    "tsup": "^8.3.0",
    "tsx": "^4.21.0",
    "typedoc": "^0.28.0",
    "typescript": "^6.0.3",
    "validator": "^13.15.35",
    "vitest": "^4.1.5"
  },
  "engines": {
    "node": ">=20"
  },
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "size-limit": [
    {
      "name": "full registry (root, all 34 countries through v0.6)",
      "path": "dist/index.js",
      "limit": "45 KB"
    },
    {
      "name": "single country — sv (smallest, format+1 mod-10 + 1 mod-11)",
      "path": "dist/countries/sv/index.js",
      "limit": "3 KB"
    },
    {
      "name": "single country — br (mid, two mod-11 specs)",
      "path": "dist/countries/br/index.js",
      "limit": "3 KB"
    },
    {
      "name": "single country — mx (largest, CURP table + RFC homoclave)",
      "path": "dist/countries/mx/index.js",
      "limit": "5 KB"
    },
    {
      "name": "single country — es (DNI letter table + CIF)",
      "path": "dist/countries/es/index.js",
      "limit": "3 KB"
    },
    {
      "name": "algorithms primitives subpath",
      "path": "dist/algorithms/index.js",
      "limit": "1 KB"
    },
    {
      "name": "v0.3 — extract helpers subpath (includes full registry for getSpec)",
      "path": "dist/extract/index.js",
      "limit": "20 KB"
    },
    {
      "name": "v0.3 — pii helpers subpath (includes full registry for getSpec)",
      "path": "dist/pii/index.js",
      "limit": "20 KB"
    },
    {
      "name": "v0.3 — i18n core subpath",
      "path": "dist/i18n/index.js",
      "limit": "2 KB"
    },
    {
      "name": "v0.3 — i18n single locale (es)",
      "path": "dist/i18n/locales/es.js",
      "limit": "1 KB"
    },
    {
      "name": "v0.3 — catalog subpath (all 3 locales, 34 countries)",
      "path": "dist/catalog/index.js",
      "limit": "30 KB"
    }
  ]
}
